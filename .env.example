# ========================================
# 营销CRM系统 - 环境变量配置模板
# ========================================
# 使用方法：
#   1. 复制此文件为 .env ：cp .env.example .env
#   2. 修改 .env 中的值
#   3. 启动时会自动读取（需安装 python-dotenv）
#
# 重要：生产环境务必修改 SECRET_KEY！

# Flask 安全密钥（务必修改为随机字符串！）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# 数据库文件存储路径（留空则默认存储在 app.py 同级目录）
# 如需挂载数据盘，可设为：/data/marketing.db
# DATABASE_PATH=

# 运行端口（默认 5000）
PORT=5000

# 调试模式（生产环境务必设为 false）
FLASK_DEBUG=false
